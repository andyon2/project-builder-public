#!/usr/bin/env bash
# notion-cli -- Shell-Wrapper fuer notion-cli.py
# Verwendet die project-builder venv (requests vorhanden)

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/../.venv/bin/python3"

if [ ! -f "$VENV_PYTHON" ]; then
    echo '{"error": "venv nicht gefunden unter '"$SCRIPT_DIR"'/../.venv/. Bitte scripts/.venv einrichten."}' >&2
    exit 1
fi

exec "$VENV_PYTHON" "$SCRIPT_DIR/notion-cli.py" "$@"
