#!/usr/bin/env bash
# Startet den Project Builder als interaktive Session
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

# Rolle bestimmen (Standard: build)
ROLE="${1:-build}"

case "$ROLE" in
  build|create)
    STARTER_FILE="$SCRIPT_DIR/starter-create.md"
    ;;
  manage)
    STARTER_FILE="$SCRIPT_DIR/starter-main.md"
    ;;
  architect)
    STARTER_FILE="$SCRIPT_DIR/starter-main.md"
    ;;
  *)
    echo "Usage: project-builder [build|manage|architect]"
    echo ""
    echo "  build      Teams bauen, rebuilden (Standard)"
    echo "  manage     Bestehende Teams betreuen (Audit, Wissen, Repos)"
    echo "  architect  An der PB-Architektur arbeiten (Fortgeschritten)"
    exit 1
    ;;
esac

if [[ ! -f "$STARTER_FILE" ]]; then
  echo "Fehler: $STARTER_FILE nicht gefunden."
  exit 1
fi

# Git-Remote-Check: Warnung wenn Remote neuere Commits hat
if git rev-parse --git-dir &>/dev/null; then
    git fetch origin --quiet 2>/dev/null || true
    LOCAL=$(git rev-parse HEAD 2>/dev/null || true)
    REMOTE=$(git rev-parse origin/main 2>/dev/null || true)
    if [[ -n "$LOCAL" && -n "$REMOTE" && "$LOCAL" != "$REMOTE" ]]; then
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "0")
        if [[ "$BEHIND" -gt 0 ]]; then
            echo ""
            echo "⚠  Remote hat $BEHIND neuere Commits. Willst du pullen? (j/n)"
            read -r ANSWER
            if [[ "$ANSWER" == "j" ]]; then
                git pull --ff-only origin main || echo "Pull fehlgeschlagen -- bitte manuell loesen."
            fi
            echo ""
        fi
    fi
fi

STARTER_CONTENT=$(cat "$STARTER_FILE")

exec claude --system-prompt-file "$PROJECT_ROOT/main-agent.md" \
  "$STARTER_CONTENT"
